# Required: Gemini AI API Key
GEMINI_API_KEY="your-gemini-api-key-here"

# Required: Supabase credentials for persistent cache + cloud file storage
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_KEY="your-supabase-anon-key-here"

# Required: Render service URL for keep-alive self-ping (prevents cold starts)
RENDER_EXTERNAL_URL="https://kpi-backend-dl16.onrender.com"

# Optional: Upstash Redis L2 Cache (serverless, survives cold restarts)
UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token-here"

# Optional: Sentry DSN for production error tracking
SENTRY_DSN="https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX"

# Optional: Stripe Billing (Pro tier — $49/month unlimited reports)
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PRICE_ID="price_your-stripe-price-id"
